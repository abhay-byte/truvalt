{
  "name": "context-mode",
  "description": "Context-mode hooks for context window protection",
  "hooks": {
    "preToolUse": [
      { "matcher": "*", "command": "context-mode hook junie pretooluse" }
    ],
    "postToolUse": [
      { "matcher": "*", "command": "context-mode hook junie posttooluse" }
    ]
  }
}
